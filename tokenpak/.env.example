# TokenPak Environment Configuration
# Copy to .env and fill in your values

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Vault configuration
TOKENPAK_VAULT_INDEX=~/.tokenpak/vault-index
TOKENPAK_RETRIEVAL_BACKEND=json_blocks  # json_blocks or sqlite

# Proxy server
TOKENPAK_PORT=8766
TOKENPAK_LOG_LEVEL=INFO

# Shadow mode (set to true to log requests without modifying them)
TOKENPAK_SHADOW_ENABLED=false

# Debug / trace
TOKENPAK_DEBUG=false

# Metrics (opt-in)
TOKENPAK_METRICS_ENABLED=false
