# TokenPak Environment Configuration
# Copy to .env and fill in your values

# Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Model routing
TOKENPAK_DEFAULT_MODEL=claude-sonnet-4-6

# Vault configuration
TOKENPAK_VAULT_PATH=~/vault
TOKENPAK_RETRIEVAL_BACKEND=json_blocks  # json_blocks or sqlite

# Proxy server
TOKENPAK_PROXY_PORT=8766
TOKENPAK_LOG_LEVEL=INFO

# Shadow mode (set to true to log requests without modifying them)
TOKENPAK_SHADOW_MODE=false

# Debug / trace
TOKENPAK_DEBUG=false
