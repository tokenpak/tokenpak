{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tip-optimization-trace.v1.json",
  "title": "TIP Optimization Trace",
  "description": "Per-request optimization trace record for telemetry and recommendations.",
  "type": "object",
  "required": ["request_id", "model", "adapter_format"],
  "properties": {
    "request_id": {"type": "string"},
    "model": {"type": "string"},
    "platform": {"type": ["string", "null"]},
    "adapter_format": {"type": "string"},
    "route_class": {"type": "string"},
    "fidelity_tier": {"type": "string"},
    "total_raw_tokens": {"type": "integer", "minimum": 0},
    "total_sent_tokens": {"type": "integer", "minimum": 0},
    "total_saved_tokens": {"type": "integer", "minimum": 0},
    "status": {"type": "string", "enum": ["ok", "error", "bypassed"]},
    "stages": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "applied"],
        "properties": {
          "name": {"type": "string"},
          "applied": {"type": "boolean"},
          "skip_reason": {"type": ["string", "null"]},
          "tokens_before": {"type": ["integer", "null"]},
          "tokens_after": {"type": ["integer", "null"]},
          "latency_ms": {"type": ["number", "null"]},
          "metadata": {"type": "object"}
        }
      }
    },
    "savings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source"],
        "properties": {
          "source": {"type": "string"},
          "raw_tokens": {"type": "integer"},
          "sent_tokens": {"type": "integer"},
          "saved_tokens": {"type": "integer"},
          "estimated_cost_saved": {"type": ["number", "null"]},
          "credited_to_tokenpak": {"type": "boolean"},
          "cost_available": {"type": "boolean"},
          "notes": {"type": ["string", "null"]}
        }
      }
    },
    "cache": {
      "type": "object",
      "properties": {
        "lookup_attempted": {"type": "boolean"},
        "hit": {"type": "boolean"},
        "scope": {"type": ["string", "null"]},
        "miss_reason": {"type": ["string", "null"]},
        "similarity_score": {"type": ["number", "null"]},
        "cache_key_digest": {"type": ["string", "null"]},
        "provider_cache_hit": {"type": "boolean"},
        "provider_prompt_cache_key": {"type": ["string", "null"]}
      }
    },
    "compression": {
      "type": "object",
      "properties": {
        "attempted": {"type": "boolean"},
        "applied": {"type": "boolean"},
        "recipe_ids": {"type": "array", "items": {"type": "string"}},
        "tokens_before": {"type": ["integer", "null"]},
        "tokens_after": {"type": ["integer", "null"]},
        "bypass_reason": {"type": ["string", "null"]},
        "protected_spans_detected": {"type": "integer"}
      }
    },
    "recommendations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["impact", "title", "detail"],
        "properties": {
          "impact": {"type": "string", "enum": ["high", "medium", "low"]},
          "title": {"type": "string"},
          "detail": {"type": "string"},
          "action": {"type": ["string", "null"]},
          "related_source": {"type": ["string", "null"]}
        }
      }
    }
  },
  "additionalProperties": false
}
