  "refresh": "30s",
  "schemaVersion": 38,
  "tags": ["tokenpak", "llm", "monitoring"],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "definition": "label_values(tokenpak_requests_total, provider)",
        "hide": 0,
        "includeAll": true,
        "multi": true,
        "name": "provider",
        "options": [],
        "query": {
          "query": "label_values(tokenpak_requests_total, provider)",
          "refId": "StandardVariableQuery"
        },
        "refresh": 2,
        "regex": "",
        "sort": 1,
        "type": "query",
        "label": "Provider"
      }
    ]
  },
  "time": { "from": "now-6h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "TokenPak Gateway Metrics",
  "uid": "tokenpak-gateway-metrics",
  "version": 1,
  "weekStart": ""
}
