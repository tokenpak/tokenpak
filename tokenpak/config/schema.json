{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TokenPak Configuration",
  "description": "Schema for TokenPak proxy configuration files",
  "type": "object",
  "properties": {
    "port": {
      "type": "integer",
      "minimum": 1024,
      "maximum": 65535,
      "description": "Port to listen on"
    },
    "mode": {
      "type": "string",
      "enum": ["strict", "hybrid", "aggressive"],
      "description": "Compression and validation mode"
    },
    "compression": {
      "type": "object",
      "properties": {
        "enabled": {"type": "boolean"},
        "max_chars": {"type": "integer", "minimum": 1},
        "threshold_tokens": {"type": "integer", "minimum": 1},
        "cache_size": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "features": {
      "type": "object",
      "properties": {
        "skeleton": {"type": "boolean"},
        "shadow_reader": {"type": "boolean"},
        "router": {"type": "boolean"},
        "validation_gate": {"type": "boolean"},
        "validation_gate_soft": {"type": "boolean"},
        "capsule_builder": {"type": "boolean"},
        "term_resolver": {"type": "boolean"}
      },
      "additionalProperties": false
    },
    "vault": {
      "type": "object",
      "properties": {
        "index_path": {"type": "string"},
        "inject_budget": {"type": "integer", "minimum": 0},
        "inject_top_k": {"type": "integer", "minimum": 0},
        "inject_min_score": {"type": "number", "minimum": 0}
      },
      "additionalProperties": false
    },
    "budget": {
      "type": "object",
      "properties": {
        "total_tokens": {"type": "integer", "minimum": 1},
        "validation_gate_cap": {"type": "integer", "minimum": 0}
      },
      "additionalProperties": false
    },
    "upstream": {
      "type": "object",
      "properties": {
        "timeout": {"type": "integer", "minimum": 0},
        "ollama": {"type": "string"}
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
