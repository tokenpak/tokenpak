{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://docs.tokenpak.ai/schemas/tokenpak/compiled-v1.json",
  "title": "TokenPak Compiled Artifact v1.0",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tokenpak_version",
    "schema_version",
    "compiled_at",
    "compiler",
    "input_block_ids",
    "ordered_blocks",
    "evidence_pack",
    "canonical_hash"
  ],
  "properties": {
    "tokenpak_version": { "type": "string", "pattern": "^1\\.0$" },
    "schema_version": { "type": "string", "pattern": "^1\\.0$" },
    "compiled_at": { "type": "string", "format": "date-time" },
    "compiler": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version"],
      "properties": {
        "name": { "type": "string" },
        "version": { "type": "string" }
      }
    },
    "input_block_ids": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "ordered_blocks": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "https://docs.tokenpak.ai/schemas/tokenpak/block-v1.json" }
    },
    "evidence_pack": { "$ref": "https://docs.tokenpak.ai/schemas/tokenpak/evidence-v1.json" },
    "canonical_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
  }
}
