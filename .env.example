# TokenPak environment template (placeholders only — NEVER commit a real .env)
# ============================================================================
# Copy this file to `.env` and fill in your own values, OR place a `.env` under
# your TokenPak home (`~/.tpk/.env`, mode 0600). `.env` is gitignored.
#
# Resolution order (highest wins): process env > ./.env > ~/.tpk/.env >
# config file > built-in defaults. Run `tokenpak config doctor` to inspect what
# is set and where each value resolves from.
#
# Secret-class values (API keys, tokens, passwords) live ONLY in your local
# `.env` (0600) — never here, never in config.yaml, never in version control.

# ── Core runtime ────────────────────────────────────────────────────────────
TOKENPAK_PORT=8766
# TOKENPAK_BIND_ADDRESS=127.0.0.1     # 0.0.0.0 for LAN/Docker exposure
TOKENPAK_LOG_LEVEL=info               # debug|info|warn|error
# TOKENPAK_CONFIG=                    # path to an alternate config file

# ── Metrics / telemetry ─────────────────────────────────────────────────────
TOKENPAK_METRICS_ENABLED=true

# ── Provider keys (secret-class high — set these in your local .env, NOT here)─
# ANTHROPIC_API_KEY=<your-anthropic-api-key>
# ANTHROPIC_BASE_URL=                 # override upstream / point at a gateway
# OPENAI_API_KEY=<your-openai-api-key>
# GOOGLE_API_KEY=<your-google-api-key>

# ── Docker Compose deployment (optional) ────────────────────────────────────
# Set to "with-cache" profile to enable Redis
COMPOSE_PROFILES=
# Resource Limits (optional, uncomment to enable)
# TOKENPAK_CPU_LIMIT=1
# TOKENPAK_MEMORY_LIMIT=512M
