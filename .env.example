# TokenPak Configuration
# Copy this file to .env and fill in your values

# API Keys (at least one required)
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
# GOOGLE_API_KEY=...

# Proxy Settings
TOKENPAK_PORT=8766
TOKENPAK_LOG_LEVEL=info

# Telemetry (optional)
TOKENPAK_TELEMETRY_DB=telemetry.db

# Cache (optional)
TOKENPAK_CACHE_ENABLED=true
TOKENPAK_CACHE_TTL=3600
