# TokenPak Docker Compose Configuration
# Copy to .env and customize for your deployment

# Port Configuration
TOKENPAK_PORT=8766

# Logging
TOKENPAK_LOG_LEVEL=info

# Metrics
TOKENPAK_METRICS_ENABLED=true

# Redis Cache (optional)
# Set to "with-cache" profile to enable Redis
COMPOSE_PROFILES=

# Resource Limits (optional, uncomment to enable)
# TOKENPAK_CPU_LIMIT=1
# TOKENPAK_MEMORY_LIMIT=512M
