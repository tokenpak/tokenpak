# TokenPak Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# ──────────────────────────────────────────────
# SECRETS — do not log, do not share
# ──────────────────────────────────────────────

# API key for authenticating clients to TokenPak proxy
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
TOKENPAK_API_KEY=

# Comma-separated list of allowed API keys (for multi-tenant setups)
# TOKENPAK_ALLOWED_KEYS=key1,key2,key3

# License key (enterprise)
# TOKENPAK_LICENSE_DIR=~/.tokenpak/license

# Upstream provider keys (passed through to providers, never stored)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# GitHub token for reference fetching (optional)
# GITHUB_TOKEN=

# Notion integration token (optional)
# NOTION_API_TOKEN=

# ──────────────────────────────────────────────
# SERVER CONFIG
# ──────────────────────────────────────────────

# Port to run TokenPak proxy on (default: 4789)
# TOKENPAK_PORT=4789

# Mode: proxy | local | agent
# TOKENPAK_MODE=proxy

# CORS allowed origins (comma-separated, default: localhost only)
# TOKENPAK_CORS_ORIGINS=http://localhost:3000,https://myapp.example.com

# ──────────────────────────────────────────────
# DATABASE / STORAGE
# ──────────────────────────────────────────────

# Path to SQLite telemetry database
# TOKENPAK_DB=~/.tokenpak/telemetry.db

# Path to A/B test database
# TOKENPAK_AB_DB=~/.tokenpak/ab.db

# ──────────────────────────────────────────────
# FEATURES
# ──────────────────────────────────────────────

# Enable cost tracking (default: true)
# TOKENPAK_COST_TRACKING=true

# Enable workflow tracking
# TOKENPAK_WORKFLOW_TRACKING=true

# Enable metrics collection
# TOKENPAK_METRICS_ENABLED=true

# Debug mode — NEVER enable in production
# TOKENPAK_DEBUG=false

# ──────────────────────────────────────────────
# INTELLIGENCE / AGENT
# ──────────────────────────────────────────────

# URL of the intelligence service
# TOKENPAK_INTELLIGENCE_URL=http://localhost:4790

# Enable agent mode
# TOKENPAK_AGENT=false

# Platform adapters (comma-separated)
# TOKENPAK_PLATFORM_ADAPTERS=openai,anthropic
